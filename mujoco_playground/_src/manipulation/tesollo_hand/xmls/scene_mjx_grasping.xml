<mujoco model="tesollo_scene">
  <include file="tesollo_wrist_large_xyz.xml"/>

  <statistic center="0. 0 0" extent="0.4" meansize="0.01"/>

  <default>
    <default class="cube">
      <geom friction=".3 0.05" conaffinity="2" condim="3"/>
    </default>
  </default>

  <visual>
    <headlight diffuse=".8 .8 .8" ambient=".2 .2 .2" specular="1 1 1"/>
    <rgba force="1 0 0 1"/>
    <global azimuth="120" elevation="-20"/>
    <map force="0.01" stiffness="500"/>
    <scale forcewidth="0.1" contactwidth="0.5" contactheight="0.2"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="800" height="800"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="1 1 1" rgb2="1 1 1" markrgb="0 0 0"
      width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0"/>
  </asset>

  <worldbody>
    <camera name="side" pos="-0.183 0.396 0.296" xyaxes="-0.783 -0.622 -0.000 0.332 -0.419 0.845"/>
    <geom name="floor" pos="0 0 -0.25" size="0 0 0.01" type="plane" material="groundplane" contype="1" conaffinity="1"/>
    <body name="goal" mocap="true" pos="0.325 0.17 0.0475">
      <!-- <geom type="mesh" mesh="cube_mesh" material="dexcube" contype="0" conaffinity="0" density="0" group="2"/> -->
      <geom type="box" size=".035 .035 .035" mass=".108" group="2" contype="0" conaffinity="0"/>
    </body>

    <body name="cube" pos="0.0 0.0 -0.21" quat="1 0 0 0" childclass="cube">
      <freejoint name="cube_freejoint"/>
      <geom name="cube" type="box" size=".035 .035 .035" mass=".0508" group="2"/>
      <site name="cube_center" pos="0 0 0" group="4"/>
    </body>
  </worldbody>

  <sensor>
    <!-- cube. -->
    <framepos name="cube_position" objtype="body" objname="cube"/>
    <framequat name="cube_orientation" objtype="body" objname="cube"/>
    <framelinvel name="cube_linvel" objtype="body" objname="cube"/>
    <frameangvel name="cube_angvel" objtype="body" objname="cube"/>
    <frameangacc name="cube_angacc" objtype="body" objname="cube"/>
    <framezaxis name="cube_upvector" objtype="body" objname="cube"/>

    <!-- hand. -->
    <framepos name="palm_position" objtype="site" objname="grasp_site"/>
    <framepos name="rl_dg_1_tip_c_position" objtype="site" objname="rl_dg_1_tip_c"/>
    <framepos name="rl_dg_2_tip_c_position" objtype="site" objname="rl_dg_2_tip_c"/>
    <framepos name="rl_dg_3_tip_c_position" objtype="site" objname="rl_dg_3_tip_c"/>
    <framepos name="rl_dg_4_tip_c_position" objtype="site" objname="rl_dg_4_tip_c"/>
    <framepos name="rl_dg_5_tip_c_position" objtype="site" objname="rl_dg_5_tip_c"/>

    <!-- goal. -->
    <framequat name="cube_goal_orientation" objtype="body" objname="goal"/>
    <framezaxis name="cube_goal_upvector" objtype="body" objname="goal"/>
  </sensor>

  <keyframe>
    <key name="home"
      qpos="
      0.05 0 -0.07 0 0.38 0
      0.06 -1.56 0.0 0.0
      -0.1 0.67 0.5 0.5
      0. 0.68 0.62 0.56
      0.1 0.6 0.46 0.6
      0.1 0.47 1.1 0.5

      0.0 0.0 -0.2 1 0 0 0"
      ctrl="
      0.05 0 0.03 0 0.38 0
      0.06 -1.56 0.6 0.6
      -0.1 0.67 0.5 0.5
      0. 0.68 0.62 0.56
      0.1 0.6 0.46 0.6
      0.1 0.47 1.1 0.5" mpos="0.25 0.16 0"
      mquat="1 0 0 0"/>
  </keyframe>
</mujoco>
