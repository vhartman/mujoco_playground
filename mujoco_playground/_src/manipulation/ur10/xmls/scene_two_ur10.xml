<mujoco>
  <visual>
    <global offwidth="1920" offheight="1080" fovy="60" />
    <scale framelength="0.5" framewidth="0.05" />
  </visual>

  <option timestep="0.005" iterations="10" ls_iterations="10" integrator="implicitfast">
    <flag eulerdamp="disable"/>
  </option>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2=".6 .8 1" width="256" height="256"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <model name="ur10" file="mujoco_ur10/ur10e.xml"/>
  </asset>

  <asset>
    <texture name="box" type="cube" fileup="assets/fileup.png" fileback="assets/fileback.png"
      filedown="assets/filedown.png" filefront="assets/filefront.png" fileleft="assets/fileleft.png"
      fileright="assets/fileright.png"/>
    <material name="box" texture="box"/>
    <texture name="box_alpha" type="cube" fileup="assets/fileup_light.png" fileback="assets/fileback_light.png"
      filedown="assets/filedown_light.png" filefront="assets/filefront_light.png" fileleft="assets/fileleft_light.png"
      fileright="assets/fileright_light.png"/>
    <material name="box_alpha" texture="box_alpha"/>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="800" height="800"/>
  </asset>

  <worldbody>
    <light pos="1.5 1.5 5.0" diffuse="2 1.9 1.9"/>
    <light pos="-1.5 -1.5 5.0" diffuse="2 1.9 1.9"/>

    <geom name="floor" pos="0 0 -0.05" size="0 0 0.05" type="plane" material="groundplane"/>
    
    <body mocap="true" name="mocap_target_1">
      <geom type="box" size="0.02 0.02 0.02" contype="0" conaffinity="0"
       material="box_alpha"/>
    </body>

    <body mocap="true" name="mocap_target_2">
      <geom type="box" size="0.02 0.02 0.02" contype="0" conaffinity="0"
       material="box_alpha"/>
    </body>

    <body name="ur10_1" pos="0.75 0.0 0.0" euler="0 0 0">
      <attach model="ur10" body="base" prefix="ur10_1:"/>
    </body>
    <body name="ur10_2" pos="-0.75 0.0 0.0" euler="0 0 180">
      <attach model="ur10" body="base" prefix="ur10_2:"/>
    </body>
  </worldbody>

  <sensor>
    <framepos name="ur10_1_ee_pos" objtype="site" objname="ur10_1:attachment_site"/>
    <framequat name="ur10_1_ee_quat" objtype="site" objname="ur10_1:attachment_site"/>

    <framepos name="ur10_2_ee_pos" objtype="site" objname="ur10_2:attachment_site"/>
    <framequat name="ur10_2_ee_quat" objtype="site" objname="ur10_2:attachment_site"/>
  </sensor>

  <keyframe>
    <key name="home" qpos="
    0 -2 1. -1 -1.63 0 
    0 -2 1. -1 -1.63 0"
    ctrl="
    0 -2 1. -1 -1.63 0
    0 -2 1. -1 -1.63 0"/>
  </keyframe>
</mujoco>